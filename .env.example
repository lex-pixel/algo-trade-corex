# =============================================
# ALGO TRADE CODEX — .env.example
#
# NASIL KULLANILIR:
# 1. Bu dosyayı kopyala: cp .env.example .env
# 2. .env dosyasındaki değerleri kendi API key'lerinle doldur
# 3. .env dosyasını KESİNLİKLE GitHub'a gönderme (.gitignore'da zaten var)
# =============================================

# --- BORSA API (TESTNET — Sahte Para) ---
# Binance Testnet: https://testnet.binance.vision
BINANCE_API_KEY=testnet_buraya_yaz
BINANCE_API_SECRET=testnet_buraya_yaz
BINANCE_TESTNET=true          # false yapınca gerçek para hesabına geçer

# Bybit Testnet: https://testnet.bybit.com
BYBIT_API_KEY=testnet_buraya_yaz
BYBIT_API_SECRET=testnet_buraya_yaz
BYBIT_TESTNET=true

# --- VERİTABANI ---
# TimescaleDB (PostgreSQL) bağlantı bilgileri
DB_HOST=localhost
DB_PORT=5432
DB_NAME=algo_trade
DB_USER=postgres
DB_PASSWORD=sifre_buraya_yaz

# --- REDIS (Önbellek) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- TELEGRAM BİLDİRİMLER ---
# Bot oluşturmak için: @BotFather'a yaz
TELEGRAM_BOT_TOKEN=token_buraya_yaz
TELEGRAM_CHAT_ID=chat_id_buraya_yaz

# --- RİSK PARAMETRELERİ ---
MAX_POSITION_RISK=0.02        # Pozisyon başına max %2 risk
MAX_DAILY_LOSS=0.05           # Günlük max %5 kayıp (Kill Switch L2)
MAX_DRAWDOWN=0.15             # Max %15 drawdown (Kill Switch L3)

# --- GENEL ---
ENV=development               # development | production
LOG_LEVEL=INFO
